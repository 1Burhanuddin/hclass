/** @file Environment variables template */

# Clerk Authentication
NEXT_PUBLIC_CLERK_PUBLISHABLE_KEY=your_clerk_publishable_key_here
CLERK_SECRET_KEY=your_clerk_secret_key_here
NEXT_PUBLIC_CLERK_SIGN_IN_URL=/auth/sign-in
NEXT_PUBLIC_CLERK_SIGN_UP_URL=/auth/sign-up
NEXT_PUBLIC_CLERK_AFTER_SIGN_IN_URL=/dashboards
NEXT_PUBLIC_CLERK_AFTER_SIGN_UP_URL=/dashboards

# Convex Backend
NEXT_PUBLIC_CONVEX_URL=your_convex_deployment_url_here

# App Configuration
NEXT_PUBLIC_APP_NAME=Harshdeep Classes Management System
NEXT_PUBLIC_APP_VERSION=1.0.0
